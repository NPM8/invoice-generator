# Copy to .env.deploy (gitignored) and fill in. Then: bun run deploy:all
# Holds secrets — never commit the filled-in .env.deploy.

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=ed9fbf8b1ab0bd6c7ed21ede2be2263f
# Optional: API token for fully headless runs. If empty, your `wrangler login` session is used.
CLOUDFLARE_API_TOKEN=

# --- Supabase (hosted project) ---
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DB password (Project Settings -> Database).
SUPABASE_DB_PASSWORD=your-db-password
# Migrations connection. Direct (db.<ref>.supabase.co) is IPv6-only — on IPv4
# networks set this to the Session-pooler URI (Settings -> Database ->
# Connection string -> "Session pooler", IPv4). Leave empty to use direct.
# e.g. postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# --- App ---
# Worker var (config). Auth is by DB scopes; pick any strong string.
ADMIN_API_KEY=change-me-strong-string
# Name for the bootstrap org + admin API key the script mints.
BOOTSTRAP_ORG_NAME=Platform Admin

{
  "name": "invoicing-service",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:api": "wrangler dev --config wrangler.api.toml",
    "dev:worker": "wrangler dev --config wrangler.invoice.toml",
    "deploy:api": "wrangler deploy --config wrangler.api.toml",
    "deploy:worker": "wrangler deploy --config wrangler.invoice.toml",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:coverage": "bun test --coverage",
    "seed": "bun run src/scripts/seed.ts",
    "generate-key": "bun run src/scripts/generate-api-key.ts",
    "generate-openapi": "bun run src/scripts/generate-openapi.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "wrangler": "^3.99.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.94.5",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.97.0",
    "effect": "^3.19.19",
    "esbuild": "^0.24.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}

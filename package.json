{
  "name": "invoicing-service",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:api": "bun run --hot src/api/index.ts",
    "dev:worker": "bun run --hot src/worker/index.ts",
    "start:api": "bun run src/api/index.ts",
    "start:worker": "bun run src/worker/index.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:coverage": "bun test --coverage",
    "seed": "bun run src/scripts/seed.ts",
    "generate-key": "bun run src/scripts/generate-api-key.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",

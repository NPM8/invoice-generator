  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-bun": "^0.87.1",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.97.0",
    "bullmq": "^5.70.0",
    "effect": "^3.19.19",
    "ioredis": "^5.9.3",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
